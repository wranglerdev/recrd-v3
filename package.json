{
  "name": "recrd-agile-testing",
  "version": "0.1.0",
  "description": "Gravador corporativo de automações: converte testes manuais web em Robot Framework + Playwright, local-first com Electron.",
  "author": "wranglerdev",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main/main.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "tsx scripts/build.ts",
    "build:renderer": "vite build",
    "build:main": "tsx scripts/build-main.ts",
    "build:version": "tsx scripts/build-version.ts",
    "typecheck": "tsc --build && tsc -p tsconfig.tests.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsx scripts/test.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "npm run build:renderer && npm run build:main",
    "test:e2e": "playwright test",
    "release": "tsx scripts/release.ts",
    "package": "electron-builder --win --x64"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.4",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.16",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.4",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.0.11",
    "vitest": "^3.0.4"
  },
  "allowScripts": {
    "esbuild@0.24.2": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "better-sqlite3@11.10.0": true
  }
}
