{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/renderer",
    "rootDir": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "jsx": "react-jsx",
    "paths": {
      "@domain/*": ["../domain/*"],
      "@application/*": ["../application/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "references": [{ "path": "../domain" }, { "path": "../application" }, { "path": "../shared" }],
  "include": ["."]
}
