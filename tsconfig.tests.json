{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/tests",
    "rootDir": ".",
    "noEmit": true,
    "composite": false,
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "jsx": "react-jsx",
    "paths": {
      "@domain/*": ["src/domain/*"],
      "@application/*": ["src/application/*"],
      "@main/*": ["src/main/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["tests", "scripts", "vite.config.ts", "vitest.config.ts", "playwright.config.ts"]
}
